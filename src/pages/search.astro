---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/search.css';
---

<BaseLayout title="搜索">
  <div class="search-page">
    <div class="search-input-wrapper">
      <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="search-input"
        class="search-input"
        type="search"
        placeholder="搜索文章..."
        autofocus
        autocomplete="off"
      />
      <button id="search-clear" class="search-clear" aria-label="清除搜索" type="button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <kbd class="search-kbd">/</kbd>
    </div>
    <div id="search-results" class="search-results">
      <div class="search-empty"><p>输入关键词开始搜索</p></div>
    </div>
  </div>
</BaseLayout>

<script>
  import MiniSearch from 'minisearch';

  const CHAR_CJK = /[一-鿿㐀-䶿\u{20000}-\u{2a6df}]/u;

  function tokenize(text: string): string[] {
    const tokens: string[] = [];
    const segments = text.split(/[\s,.;:!?()\[\]{}'"<>\/\\|`~@#$%^&*+=　-〿＀-￯]+/);
    for (const seg of segments) {
      if (!seg) continue;
      if (CHAR_CJK.test(seg)) {
        for (let i = 0; i < seg.length; i++) {
          tokens.push(seg[i]);
          if (i < seg.length - 1) tokens.push(seg[i] + seg[i + 1]);
        }
      } else {
        tokens.push(seg.toLowerCase());
      }
    }
    return tokens;
  }

  function escapeRegex(s: string): string {
    return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.appendChild(document.createTextNode(s));
    return div.innerHTML;
  }

  function formatDate(iso: string): string {
    return new Date(iso).toLocaleDateString('zh-CN');
  }

  // Find a relevant snippet around the first matching term
  function getSnippet(text: string, queryTerms: string[], maxLen = 150): string {
    let bestIdx = -1;
    const lower = text.toLowerCase();
    for (const term of queryTerms) {
      if (!term) continue;
      const idx = lower.indexOf(term.toLowerCase());
      if (idx !== -1 && (bestIdx === -1 || idx < bestIdx)) bestIdx = idx;
    }

    const start = bestIdx >= 0 ? Math.max(0, bestIdx - 60) : 0;
    let snippet = text.slice(start, start + maxLen);
    if (start > 0) snippet = '…' + snippet;
    if (start + maxLen < text.length) snippet = snippet + '…';
    return snippet;
  }

  function highlight(text: string, terms: string[]): string {
    let escaped = escapeHtml(text);
    const uniq = [...new Set(terms)]
      .filter(Boolean)
      .sort((a, b) => b.length - a.length);
    if (uniq.length === 0) return escaped;

    const alternation = uniq.map((t) => escapeRegex(escapeHtml(t))).join('|');
    const regex = new RegExp(`(${alternation})`, 'gi');
    return escaped.replace(regex, '<mark>$1</mark>');
  }

  // --- State ---
  let miniSearch: MiniSearch | null = null;
  let selectedIndex = -1;
  let debounceTimer: ReturnType<typeof setTimeout> | null = null;

  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsEl = document.getElementById('search-results')!;
  const clearBtn = document.getElementById('search-clear')!;

  // --- UI updates ---
  function showLoading() {
    resultsEl.innerHTML = '<div class="search-loading"><p>加载搜索索引…</p></div>';
  }

  function showEmpty() {
    selectedIndex = -1;
    resultsEl.innerHTML = '<div class="search-empty"><p>输入关键词开始搜索</p></div>';
  }

  function showNoResults(query: string) {
    selectedIndex = -1;
    resultsEl.innerHTML =
      `<div class="search-no-results"><p>未找到与 &ldquo;<strong>${escapeHtml(query)}</strong>&rdquo; 相关的结果</p></div>`;
  }

  function showError() {
    resultsEl.innerHTML = '<div class="search-error"><p>搜索索引加载失败，请刷新页面重试</p></div>';
  }

  function showResults(hits: any[], query: string) {
    selectedIndex = -1;
    const queryTerms = query.trim().split(/\s+/).filter(Boolean);

    resultsEl.innerHTML = hits
      .map((r, i) => {
        const text = r.description || r.body || '';
        const snippet = getSnippet(text, queryTerms);
        const highlighted = highlight(snippet, queryTerms);
        return `
        <div class="search-result" data-index="${i}">
          <div class="search-result-title">
            <a href="/posts/${r.slug}/">${escapeHtml(r.title)}</a>
          </div>
          <div class="search-result-meta">${formatDate(r.date)}</div>
          ${highlighted ? `<div class="search-result-snippet">${highlighted}</div>` : ''}
          <div class="search-result-tags">
            ${r.tags.map((t: string) => `<a href="/tags/${encodeURIComponent(t)}/" class="tag-chip">#${escapeHtml(t)}</a>`).join('')}
          </div>
        </div>`;
      })
      .join('');
  }

  // --- Search ---
  function doSearch(query: string) {
    if (!miniSearch) return;
    const q = query.trim();
    if (!q) {
      showEmpty();
      updateURL('');
      return;
    }

    const hits = miniSearch.search(q, { prefix: true, fuzzy: 0.2 });
    if (hits.length === 0) {
      showNoResults(q);
    } else {
      showResults(hits.slice(0, 20), q);
    }
  }

  function updateURL(query: string) {
    const url = query ? `/search?q=${encodeURIComponent(query)}` : '/search';
    history.replaceState(null, '', url);
  }

  // --- Init ---
  async function init() {
    showLoading();

    try {
      const res = await fetch('/search-index.json');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const posts = await res.json();

      miniSearch = new MiniSearch({
        fields: ['title', 'description', 'tags', 'body'],
        storeFields: ['title', 'date', 'description', 'tags', 'slug', 'body'],
        tokenize,
        searchOptions: {
          boost: { title: 3, description: 2, tags: 1.5 },
          fuzzy: 0.2,
          prefix: true,
        },
      });

      miniSearch.addAll(posts);

      const q = new URLSearchParams(window.location.search).get('q');
      if (q) {
        input.value = q;
        clearBtn.classList.add('visible');
        doSearch(q);
      } else {
        showEmpty();
      }
    } catch {
      showError();
    }
  }

  // --- Events ---
  input.addEventListener('input', () => {
    if (input.value) {
      clearBtn.classList.add('visible');
    } else {
      clearBtn.classList.remove('visible');
    }

    if (debounceTimer) clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      doSearch(input.value);
      updateURL(input.value);
    }, 300);
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    clearBtn.classList.remove('visible');
    showEmpty();
    updateURL('');
    input.focus();
  });

  // --- Keyboard ---
  document.addEventListener('keydown', (e) => {
    // Global / shortcut
    if (
      e.key === '/' &&
      document.activeElement !== input &&
      (document.activeElement?.tagName !== 'INPUT' || (document.activeElement as HTMLElement)?.getAttribute('type') !== 'search') &&
      document.activeElement?.tagName !== 'TEXTAREA'
    ) {
      e.preventDefault();
      input.focus();
      input.select();
      return;
    }

    if (document.activeElement !== input) return;

    const items = resultsEl.querySelectorAll<HTMLElement>('.search-result');

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (items.length > 0) {
        selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
        updateSelection(items);
      }
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (items.length > 0) {
        selectedIndex = Math.max(selectedIndex - 1, -1);
        updateSelection(items);
      }
    } else if (e.key === 'Enter' && selectedIndex >= 0) {
      e.preventDefault();
      const link = items[selectedIndex]?.querySelector('a');
      if (link) window.location.href = link.href;
    } else if (e.key === 'Escape') {
      e.preventDefault();
      selectedIndex = -1;
      updateSelection(items);
      input.blur();
    }
  });

  function updateSelection(items: NodeListOf<HTMLElement>) {
    items.forEach((item, i) => {
      if (i === selectedIndex) {
        item.dataset.selected = 'true';
        item.scrollIntoView({ block: 'nearest' });
      } else {
        delete item.dataset.selected;
      }
    });
  }

  // Browser back/forward
  window.addEventListener('popstate', () => {
    const q = new URLSearchParams(window.location.search).get('q') || '';
    input.value = q;
    if (q) {
      clearBtn.classList.add('visible');
    } else {
      clearBtn.classList.remove('visible');
    }
    doSearch(q);
  });

  init();
</script>
