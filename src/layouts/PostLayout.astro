---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import '../styles/post.css';

export interface Props {
  post: CollectionEntry<'posts'>;
  headings?: { depth: number; slug: string; text: string }[];
}

const { post, headings = [] } = Astro.props;
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    <a href="/" class="post-back">&larr; 返回首页</a>

    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-meta">{post.data.date.toLocaleDateString('zh-CN')}</p>
      <div class="post-tags">
        {post.data.tags.map(tag => (
          <a class="tag-chip" href={`/tags/${tag}`}>#{tag}</a>
        ))}
      </div>
    </header>

    <div class="post-content" id="post-content">
      <slot />
    </div>
  </article>

  <section class="post-comments" id="giscus-comments">
    <script>
      const giscusTheme = (() => {
        try { return localStorage.getItem('theme') || null; } catch {}
        return null;
      })() || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

      const s = document.createElement('script');
      s.src = 'https://giscus.app/client.js';
      s.setAttribute('data-repo', 'Quinnmush/quinnmush.github.io');
      s.setAttribute('data-repo-id', 'R_kgDOSfXTUA');
      s.setAttribute('data-category', 'Announcements');
      s.setAttribute('data-category-id', 'DIC_kwDOSfXTUM4C9SKZ');
      s.setAttribute('data-mapping', 'pathname');
      s.setAttribute('data-strict', '0');
      s.setAttribute('data-reactions-enabled', '1');
      s.setAttribute('data-emit-metadata', '0');
      s.setAttribute('data-input-position', 'bottom');
      s.setAttribute('data-theme', giscusTheme);
      s.setAttribute('data-lang', 'zh-CN');
      s.crossOrigin = 'anonymous';
      document.getElementById('giscus-comments').appendChild(s);
    </script>
  </section>

  <aside class="toc">
    <nav>
      <div class="toc-title">目录</div>
      <ul class="toc-list">
        {headings.filter(h => h.depth <= 3).map(h => (
          <li class={`toc-item ${h.depth === 3 ? 'toc-depth-3' : 'toc-depth-2'}`}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
    <a class="toc-comment-link" href="#giscus-comments">跳转评论</a>
  </aside>

  <script>
    const updateReadingProgress = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.body.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
      const clamped = Math.max(progress, 0.02);
      document.documentElement.style.setProperty('--reading-progress', clamped);
      const tocList = document.querySelector('.toc-list');
      if (tocList) {
        const headingItems = tocList.querySelectorAll('.toc-item');
        let maxH = 0;
        headingItems.forEach(item => { maxH += item.offsetHeight; });
        const gap = parseFloat(getComputedStyle(tocList).gap) || 6;
        maxH += (headingItems.length - 1) * gap;
        tocList.style.setProperty('--bar-h', Math.max(2, clamped * Math.max(maxH, 0)) + 'px');
      }
    };
    window.addEventListener('scroll', updateReadingProgress, { passive: true });
    updateReadingProgress();
  </script>

  <script>
    const updateTOCHighlight = () => {
      const h2s = document.querySelectorAll('.post-content h2[id]');
      const h3s = document.querySelectorAll('.post-content h3[id]');
      if (h2s.length === 0) return;

      const referenceLine = 120;

      // 当前 h2：最后一个顶部越过 referenceLine 的 h2
      let activeH2 = null;
      for (const h2 of h2s) {
        if (h2.getBoundingClientRect().top <= referenceLine) activeH2 = h2;
        else break;
      }
      if (!activeH2) activeH2 = h2s[0];

      // 当前 h3：在 activeH2 和下一个 h2 之间，最后一个顶部越过 referenceLine 的 h3
      let activeH3 = null;
      let nextH2Top = Infinity;
      const activeH2Top = activeH2.getBoundingClientRect().top;
      for (const h2 of h2s) {
        const rect = h2.getBoundingClientRect();
        if (rect.top > activeH2Top && rect.top > referenceLine) {
          nextH2Top = rect.top;
          break;
        }
      }
      for (const h3 of h3s) {
        const rect = h3.getBoundingClientRect();
        if (rect.top > activeH2Top && rect.top <= referenceLine && rect.top < nextH2Top) {
          activeH3 = h3;
        }
      }

      document.querySelectorAll('.toc-item.active').forEach(el => el.classList.remove('active'));
      if (activeH2) {
        const link = document.querySelector(`.toc a[href="#${activeH2.id}"]`);
        if (link) link.closest('li').classList.add('active');
      }
      if (activeH3) {
        const link = document.querySelector(`.toc a[href="#${activeH3.id}"]`);
        if (link) link.closest('li').classList.add('active');
      }
    };

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => { updateTOCHighlight(); ticking = false; });
        ticking = true;
      }
    }, { passive: true });
    updateTOCHighlight();
  </script>
</BaseLayout>
