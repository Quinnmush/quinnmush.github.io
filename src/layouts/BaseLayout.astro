---
import '../styles/variables.css';
import '../styles/reset.css';
import { SITE } from '../config';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} · ${SITE.title}` : SITE.title}</title>
    <meta name="description" content={description || SITE.description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="site-logo">{SITE.title}</a>
        <a href="/tags">标签</a>
        <a href="/search">搜索</a>
        <button id="toc-toggle" class="toc-toggle">目录</button>
        <button id="theme-toggle" class="theme-toggle" aria-label="切换亮暗模式">
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </nav>
    </header>
    <main class="main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} {SITE.author}</p>
    </footer>
    <script>
      const STORAGE_KEY = 'theme';
      const HTML = document.documentElement;

      function getPreferred() {
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }

      function setTheme(theme) {
        HTML.dataset.theme = theme;
        try { localStorage.setItem(STORAGE_KEY, theme); } catch {}
      }

      const saved = (() => { try { return localStorage.getItem(STORAGE_KEY); } catch {} })();
      setTheme(saved || getPreferred());

      function syncGiscusTheme() {
        const iframe = document.querySelector('iframe.giscus-frame');
        if (iframe) {
          iframe.contentWindow.postMessage(
            { giscus: { setConfig: { theme: HTML.dataset.theme } } },
            'https://giscus.app',
          );
        }
      }
      document.addEventListener('giscus:load', syncGiscusTheme);

      document.getElementById('theme-toggle').addEventListener('click', () => {
        const next = HTML.dataset.theme === 'dark' ? 'light' : 'dark';
        setTheme(next);
        syncGiscusTheme();
      });

      // 移动端 TOC 下拉（仅文章页显示按钮）
      const tocToggle = document.getElementById('toc-toggle');
      const postContent = document.getElementById('post-content');
      if (tocToggle && postContent) {
        const tocMedia = window.matchMedia('(max-width: 1199px)');
        tocMedia.addEventListener('change', () => {
          tocToggle.style.display = tocMedia.matches ? 'inline-flex' : '';
        });
        if (tocMedia.matches) tocToggle.style.display = 'inline-flex';

        const headings = postContent.querySelectorAll('h2[id], h3[id]');
        if (headings.length > 0) {
          const dropdown = document.createElement('div');
          dropdown.className = 'toc-dropdown';
          dropdown.id = 'toc-dropdown';
          const list = document.createElement('ul');
          headings.forEach(h => {
            const li = document.createElement('li');
            const depth = h.tagName === 'H3' ? 'toc-depth-3' : 'toc-depth-2';
            li.innerHTML = `<a href="#${h.id}" class="${depth}">${h.textContent}</a>`;
            list.appendChild(li);
          });
          const sep = document.createElement('li');
          sep.innerHTML = '<hr>';
          list.appendChild(sep);
          const commentLi = document.createElement('li');
          commentLi.innerHTML = '<a href="#giscus-comments">跳转评论</a>';
          list.appendChild(commentLi);
          dropdown.appendChild(list);
          document.querySelector('.site-nav').appendChild(dropdown);

          tocToggle.addEventListener('click', (e) => {
            e.stopPropagation();
            dropdown.classList.toggle('open');
          });

          dropdown.addEventListener('click', () => {
            dropdown.classList.remove('open');
          });

          document.addEventListener('click', (e) => {
            if (!tocToggle.contains(e.target) && !dropdown.contains(e.target)) {
              dropdown.classList.remove('open');
            }
          });
        }
      }
    </script>
  </body>
</html>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
  }

  .site-nav {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    position: relative;
  }

  .site-logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .site-logo:hover {
    color: var(--color-accent);
  }

  .theme-toggle {
    margin-left: auto;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-text-secondary);
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .theme-toggle:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-bg-alt);
  }

  .toc-toggle {
    display: none;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: 0.25rem 0.625rem;
    font-size: 0.8125rem;
    font-family: inherit;
    cursor: pointer;
    color: var(--color-text-secondary);
    transition: color 0.2s, border-color 0.2s;
  }

  .toc-toggle:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }


  .icon-sun,
  .icon-moon {
    display: none;
  }

  [data-theme="dark"] .icon-moon,
  :root:not([data-theme="light"]) .icon-moon {
    display: block;
  }

  [data-theme="light"] .icon-sun {
    display: block;
  }

  /* 无手动设置时跟随系统 */
  @media (prefers-color-scheme: light) {
    :root:not([data-theme]) .icon-sun {
      display: block;
    }
    :root:not([data-theme]) .icon-moon {
      display: none;
    }
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .icon-moon {
      display: block;
    }
    :root:not([data-theme]) .icon-sun {
      display: none;
    }
  }

  .main {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md);
    min-height: calc(100vh - 200px);
  }

  .site-footer {
    text-align: center;
    padding: var(--space-lg);
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    border-top: 1px solid var(--color-border);
  }
</style>

<style is:global>
  .toc-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-accent);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    max-height: 60vh;
    overflow-y: auto;
    padding: var(--space-md);
    z-index: 100;
    scrollbar-width: thin;
    scrollbar-color: var(--color-accent) transparent;
  }

  .toc-dropdown::-webkit-scrollbar {
    width: 1px;
  }
  .toc-dropdown::-webkit-scrollbar-track {
    background: transparent;
  }
  .toc-dropdown::-webkit-scrollbar-thumb {
    background: var(--color-accent);
    border-radius: 1px;
  }

  .toc-dropdown.open {
    display: block;
  }

  .toc-dropdown ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .toc-dropdown a {
    display: block;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }

  .toc-dropdown a:hover {
    color: var(--color-accent);
    background: var(--color-bg-alt);
  }

  .toc-dropdown .toc-depth-3 {
    padding-left: var(--space-lg);
  }

  .toc-dropdown hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-sm) 0;
  }

  @media (min-width: 1200px) {
    .toc-dropdown {
      display: none !important;
    }
  }

  .toc-list .toc-depth-3 a {
    padding-left: 1rem;
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .toc-list .toc-depth-3.active a {
    padding-left: 2.5rem;
  }

  .toc-dropdown a.toc-depth-3 {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-secondary);
    font-style: italic;
    opacity: 0.7;
  }

  .toc-dropdown .toc-depth-3.active {
    padding-left: 2.5rem;
  }
</style>
